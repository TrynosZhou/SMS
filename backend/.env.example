# Server Configuration
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sms_db
# Set to true to auto-create/update tables (useful in dev or first deploy); set false in production after schema exists
# DB_SYNC=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_characters
JWT_EXPIRES_IN=7d

# Docker Configuration (if using Docker for backend)
# DB_HOST=postgres
# DB_PORT=5432

# WhatsApp Cloud API (Meta) — optional; required for results-published notifications
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_API_URL=https://graph.facebook.com
# WHATSAPP_SEND_DELAY_MS=350
# WHATSAPP_ADMIN_PHONES=+263771234567,+263772345678

